<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- League of Legends Color Palette -->
    <Styles.Resources>
        <!-- Primary LoL Colors -->
        <SolidColorBrush x:Key="LoLGold" Color="#C89B3C"/>
        <SolidColorBrush x:Key="LoLBlue" Color="#0596AA"/>
        <SolidColorBrush x:Key="LoLDarkBlue" Color="#1E2328"/>
        <SolidColorBrush x:Key="LoLDarkGray" Color="#3C3C41"/>
        <SolidColorBrush x:Key="LoLLightGray" Color="#5BC0DE"/>
        <SolidColorBrush x:Key="LoLBackground" Color="#010A13"/>
        <SolidColorBrush x:Key="LoLCardBackground" Color="#1E2328"/>
        <SolidColorBrush x:Key="LoLBorder" Color="#C89B3C"/>
        <SolidColorBrush x:Key="LoLAccent" Color="#F0E6D2"/>
        <SolidColorBrush x:Key="LoLHover" Color="#463714"/>
        <SolidColorBrush x:Key="LoLPressed" Color="#695F2B"/>
        
        <!-- Team Colors -->
        <SolidColorBrush x:Key="BlueTeam" Color="#0F2027"/>
        <SolidColorBrush x:Key="RedTeam" Color="#2C1810"/>
        
        <!-- Typography -->
        <FontFamily x:Key="LoLFont">Inter, Segoe UI, Arial</FontFamily>
    </Styles.Resources>

    <!-- Window Styles -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource LoLBackground}"/>
        <Setter Property="FontFamily" Value="{DynamicResource LoLFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLAccent}"/>
    </Style>

    <!-- Button Styles -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource LoLDarkBlue}"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLGold}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLBorder}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="4"/>
    </Style>
    
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource LoLHover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLGold}"/>
    </Style>
    
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{DynamicResource LoLPressed}"/>
    </Style>

    <!-- Primary Button -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource LoLGold}"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLDarkBlue}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Card Styles -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource LoLCardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="8"/>
    </Style>

    <!-- TextBlock Headers -->
    <Style Selector="TextBlock.header">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLGold}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style Selector="TextBlock.subheader">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLAccent}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- ListBox Styles -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="{DynamicResource LoLCardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource LoLGold}"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLDarkBlue}"/>
    </Style>

    <!-- TextBox Styles -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource LoLDarkBlue}"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLAccent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="IsEnabled" Value="True"/>
        <Setter Property="AcceptsReturn" Value="False"/>
        <Setter Property="AcceptsTab" Value="False"/>
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource LoLGold}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- CheckBox Styles -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource LoLAccent}"/>
        <Setter Property="Margin" Value="4"/>
    </Style>

    <!-- Team Styles -->
    <Style Selector="Border.blue-team">
        <Setter Property="Background" Value="{DynamicResource BlueTeam}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLBlue}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border.red-team">
        <Setter Property="Background" Value="{DynamicResource RedTeam}"/>
        <Setter Property="BorderBrush" Value="#DC3545"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Wheel Animation -->
    <Style Selector="Border.wheel">
        <Setter Property="Background" Value="{DynamicResource LoLCardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLGold}"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="CornerRadius" Value="200"/>
    </Style>

    <!-- Tab Button Styles -->
    <Style Selector="Button.tab-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLAccent}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="2,0"/>
    </Style>
    
    <Style Selector="Button.tab-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource LoLHover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLGold}"/>
    </Style>
    
    <Style Selector="Button.tab-button.selected">
        <Setter Property="Background" Value="{DynamicResource LoLGold}"/>
        <Setter Property="Foreground" Value="{DynamicResource LoLDarkBlue}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoLGold}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Danger Button -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="#DC3545"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#DC3545"/>
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="2"/>
    </Style>
    
    <Style Selector="Button.danger:pointerover">
        <Setter Property="Background" Value="#C82333"/>
        <Setter Property="BorderBrush" Value="#C82333"/>
    </Style>
</Styles>
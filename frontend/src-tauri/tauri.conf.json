{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoL Custom Game Helper",
  "version": "2.0.1",
  "identifier": "com.daviddemon.lolcustoms",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LoL Custom Game Helper",
        "width": 1100,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
